# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── Optional: model overrides ─────────────────────────────────────────────────
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# ── ChromaDB ──────────────────────────────────────────────────────────────────
# Path where benchmark embeddings are stored.
# On Railway/Render the benchmark data is auto-ingested on every cold start,
# so this can be left as the default.
CHROMA_DB_PATH=./chroma_db

# ── Environment ───────────────────────────────────────────────────────────────
# Set to "production" to:
#   • Hide /docs and /redoc API explorer
#   • Enforce strict CORS (only ALLOWED_ORIGINS)
ENVIRONMENT=production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of frontend origins that may call this API.
# Add your Vercel deployment URL here.
ALLOWED_ORIGINS=https://insuresight.vercel.app
